# Database
DATABASE_URL=postgresql+asyncpg://ribcage:ribcage@localhost:5432/ribcage

# Redis
REDIS_URL=redis://localhost:6379/0

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=ribcage-dev-key

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=ribcage
S3_SECRET_KEY=ribcage-secret
S3_BUCKET=ribcage

# Auth
JWT_SECRET=ribcage-dev-secret-change-in-production
CORS_ORIGINS=http://localhost:3000

# Observability
PROMETHEUS_ENABLED=true
